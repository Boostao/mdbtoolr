#!/bin/sh
set -eu

PKG_DIR="$(pwd)"
SRC_DIR="$PKG_DIR/src/mdbtools"
WORK_DIR="${TMPDIR:-/tmp}/mdbtoolr-mdbtools-build-$$"
SHIM_DIR="${TMPDIR:-/tmp}/mdbtoolr-mdbtools-shims-$$"
PREFIX_DIR="${TMPDIR:-/tmp}/mdbtoolr-mdbtools-prefix-$$"
PKG_BIN_DIR="$PKG_DIR/inst/mdbtools/bin"

cleanup() {
  rm -rf "$WORK_DIR" "$SHIM_DIR" "$PREFIX_DIR"
}

trap cleanup EXIT INT TERM

echo "[mdbtoolr] Building bundled mdbtools"

if [ ! -d "$SRC_DIR" ]; then
  echo "[mdbtoolr] ERROR: Missing vendored source at $SRC_DIR" >&2
  exit 1
fi

for cmd in make pkg-config; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "[mdbtoolr] ERROR: Required build tool '$cmd' not found" >&2
    exit 1
  fi
done

mkdir -p "$WORK_DIR"
cp -R "$SRC_DIR"/. "$WORK_DIR"/

mkdir -p "$SHIM_DIR"

if ! command -v flex >/dev/null 2>&1; then
  cat > "$SHIM_DIR/flex" <<'EOF'
#!/bin/sh
if [ "${1:-}" = "--version" ] || [ "${1:-}" = "-V" ]; then
  echo "flex 2.6.4"
  exit 0
fi

cat > lex.yy.c <<'C_EOF'
int yylex(void) { return 0; }
int yywrap(void) { return 1; }
C_EOF
exit 0
EOF
  chmod +x "$SHIM_DIR/flex"
fi

if ! command -v yacc >/dev/null 2>&1; then
  cat > "$SHIM_DIR/yacc" <<'EOF'
#!/bin/sh
if [ "${1:-}" = "-V" ] || [ "${1:-}" = "--version" ]; then
  echo "bison (GNU Bison) 3.8.2"
  exit 0
fi

cat > y.tab.c <<'C_EOF'
int yyparse(void) { return 0; }
C_EOF
cat > y.tab.h <<'H_EOF'
#ifndef YY_TAB_H
#define YY_TAB_H
int yyparse(void);
#endif
H_EOF
exit 0
EOF
  chmod +x "$SHIM_DIR/yacc"
fi

export PATH="$SHIM_DIR:$PATH"

mkdir -p "$PREFIX_DIR" "$PKG_BIN_DIR"

cd "$WORK_DIR"

if [ ! -x "$WORK_DIR/configure" ]; then
  echo "[mdbtoolr] ERROR: Missing configure script in vendored mdbtools source" >&2
  exit 1
fi

./configure \
  --prefix="$PREFIX_DIR" \
  --disable-man \
  --disable-maintainer-mode \
  --disable-shared \
  --enable-static

make -j"${MAKE_NCPUS:-1}"
make install

if [ ! -x "$PREFIX_DIR/bin/mdb-tables" ]; then
  echo "[mdbtoolr] ERROR: mdbtools build succeeded but mdb-tables was not installed" >&2
  exit 1
fi

rm -f "$PKG_BIN_DIR"/*
cp "$PREFIX_DIR"/bin/mdb-* "$PKG_BIN_DIR"/
chmod 755 "$PKG_BIN_DIR"/mdb-*

echo "[mdbtoolr] Bundled mdbtools installed to $PKG_BIN_DIR"
